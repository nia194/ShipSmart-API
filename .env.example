# ShipSmart API (Python / FastAPI + MCP tools) — environment variables
# Copy to .env and fill in real values for local development.
# Production values are set in the Render dashboard (never commit real secrets).

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Inter-service / CORS ─────────────────────────────────────────────────────
INTERNAL_JAVA_API_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Vector Store (RAG persistence) ───────────────────────────────────────────
# memory = in-process (lost on restart); pgvector = Supabase PostgreSQL
VECTOR_STORE_TYPE=memory
DATABASE_URL=
PGVECTOR_TABLE=rag_chunks

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Leave empty for EchoClient (mock, no external AI calls)
# Set to one of: openai, gemini, anthropic, llama
LLM_PROVIDER=
OPENAI_API_KEY=

# ── Task-based LLM Routing (optional) ────────────────────────────────────────
# Per-task provider selection. Empty = inherit LLM_PROVIDER.
LLM_PROVIDER_REASONING=
LLM_PROVIDER_SYNTHESIS=
LLM_PROVIDER_FALLBACK=echo

# ── Embeddings ───────────────────────────────────────────────────────────────
# Leave empty for LocalHashEmbedding (lexical, not semantic)
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── RAG / Knowledge Base ─────────────────────────────────────────────────────
RAG_AUTO_INGEST=true
RAG_DOCUMENTS_PATH=data/documents
RAG_TOP_K=3
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# ── Providers and tools ──────────────────────────────────────────────────────
SHIPPING_PROVIDER=mock
ENABLE_TOOLS=true
